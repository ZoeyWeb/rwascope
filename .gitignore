# ── OS / Editor ───────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# OpenClaw agent metadata — these files belong to the OpenClaw agent runtime,
# not to this project. They should never be committed to the rwascope repo.
# (See ~/.openclaw/workspace/WORKFLOW.md for the agent file split.)
/AGENTS.md
/IDENTITY.md
/SOUL.md
/TOOLS.md
/USER.md
/HEARTBEAT.md
/MEMORY.md
/BOOTSTRAP.md
/.openclaw/
/memory/

# ── Live data files (maintained by server cron, never committed) ──────────────
web/public/data/leaderboard.json
web/public/data/assets/assets-live.json

# ── Browser testing binaries (never commit) ───────────────────────────────────
web/chrome/
*.app/
