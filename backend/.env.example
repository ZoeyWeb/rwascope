# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://rwauser:rwapassword@localhost:5432/rwascope_backend

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_64_char_random_hex_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI (DeepSeek) ─────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["https://rwa-index.com","https://raterwa.rwa-index.com","http://localhost:5173"]

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@rwa-index.com
EMAIL_FROM_NAME=RWAscope

# ── Frontend URL (used in email links) ───────────────────────────────────────
FRONTEND_URL=https://rwa-index.com

# ── Cloudflare Turnstile (bot protection on /register) ───────────────────────
# Get from: https://dash.cloudflare.com → Turnstile
TURNSTILE_SECRET_KEY=0x4AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# ── Auto-approval rules ───────────────────────────────────────────────────────
# Comma-separated domain TLD suffixes (e.g. "edu" matches any .edu domain)
AUTO_APPROVE_DOMAINS=edu,edu.hk,edu.cn,edu.sg,edu.tw,ac.uk,ac.nz,ac.jp,edu.au,gov,gov.hk,gov.cn,gov.sg
# Comma-separated exact domain names (always auto-approved regardless of TLD)
AUTO_APPROVE_WHITELIST=hkma.gov.hk,sfc.hk,bis.org,imf.org,worldbank.org,adb.org,oecd.org
